{
  "name": "@pleaseai/eslint-config",
  "type": "module",
  "version": "0.0.1",
  "description": "ESLint config for PleaseAI projects",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package-json": {
      "types": "./dist/package-json.d.ts",
      "import": "./dist/package-json.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "peerDependencies": {
    "eslint": "^9.10.0 || ^10.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "eslint-plugin-package-json": "^0.30.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0"
  }
}
